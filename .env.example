# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# ---------------------------------------------------------------------------
# Primary database (read-write)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ats_test
DB_USER=postgres
DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Read-replica database (read-only)
# Leave DB_REPLICA_HOST blank (or unset) to use the primary pool for reads.
# ---------------------------------------------------------------------------
# DB_REPLICA_HOST=replica.example.com
# DB_REPLICA_PORT=5432
# DB_REPLICA_NAME=ats_test
# DB_REPLICA_USER=postgres
# DB_REPLICA_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Connection pool tuning
# ---------------------------------------------------------------------------
# Maximum clients per pool (default: 10)
# DB_POOL_MAX=10

# Milliseconds before an idle client is closed (default: 30000)
# DB_IDLE_TIMEOUT_MS=30000

# Milliseconds to wait for a connection before timing out (default: 5000)
# DB_CONNECTION_TIMEOUT_MS=5000

# Number of health-check retries on startup with exponential back-off (default: 5)
# DB_HEALTH_CHECK_RETRIES=5

# ---------------------------------------------------------------------------
# Backup & restore
# ---------------------------------------------------------------------------
# Directory where backup files are written (default: ./backups)
# DB_BACKUP_DIR=./backups

# Hours between automatic scheduled backups; set to 0 to disable (default: 24)
# DB_BACKUP_SCHEDULE_HOURS=24

# Maximum number of backup files to keep; older files are pruned (default: 7)
# DB_BACKUP_MAX_COUNT=7

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Resume uploads
# ---------------------------------------------------------------------------
# Directory where uploaded resume files are stored (default: ./uploads/resumes)
# RESUME_UPLOAD_DIR=./uploads/resumes

# ---------------------------------------------------------------------------
# Authentication — generate a strong random secret for production
# ---------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_secret
